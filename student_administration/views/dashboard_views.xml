<odoo>
    <!-- DASHBOARD VIEW -->
    <record id="view_dashboard_form" model="ir.ui.view">
        <field name="name">dashboard.form</field>
        <field name="model">student.dashboard</field>
        <field name="arch" type="xml">
            <form string="Student Dashboard">
                <group>
                    <group>
                        <field name="total_students" string="Total Students" widget="statcard"/>
                    </group>
                    <group>
                        <field name="attendance_percentage" string="Attendance %" widget="statcard"/>
                    </group>
                    <group>
                        <field name="leave_count" string="Leave Count" widget="statcard"/>
                    </group>
                    <group>
                        <field name="pass_percentage" string="Pass %" widget="statcard"/>
                    </group>
                </group>
                <footer>
                    <button name="action_refresh" string="Refresh" type="object" class="btn-primary"/>
                    <button name="action_diagnose" string="Diagnose" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- DASHBOARD ACTION -->
    <record id="action_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">student.dashboard</field>
        <field name="view_mode">form</field>
        <field name="context">{'create': False}</field>
    </record>
</odoo>
