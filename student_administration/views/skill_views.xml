<odoo>
    <!-- List View -->
    <record id="view_skill_tree" model="ir.ui.view">
        <field name="name">skill.list</field>
        <field name="model">student.skill</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_skill_form" model="ir.ui.view">
        <field name="name">skill.form</field>
        <field name="model">student.skill</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g., Python Programming"/>
                        <field name="category" placeholder="e.g., Programming, Design, Communication"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_skill_search" model="ir.ui.view">
        <field name="name">skill.search</field>
        <field name="model">student.skill</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_skill" model="ir.actions.act_window">
        <field name="name">Skills</field>
        <field name="res_model">student.skill</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
