<odoo>
    <!-- Kanban View -->
    <record id="view_student_kanban" model="ir.ui.view">
        <field name="name">student.kanban</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="student_id"/>
                <field name="image"/>
                <field name="skills"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="class_name"/>
                <field name="course"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-start gap-3">
                            <div class="flex-shrink-0">
                                <field name="image" widget="image" options="{'size': [72, 72], 'preview_image': 'image'}"/>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-bold fs-5">
                                    <field name="name"/>
                                </div>
                                <div class="text-muted mb-2">
                                    <field name="student_id"/>
                                </div>
                                <div t-if="record.class_name.raw_value">
                                    <strong>Department:</strong>
                                    <field name="class_name"/>
                                </div>
                                <div t-if="record.course.raw_value">
                                    <strong>Course:</strong>
                                    <field name="course"/>
                                </div>
                                <div t-if="record.skills.raw_value">
                                    <strong>Skills:</strong>
                                    <field name="skills"/>
                                </div>
                                <div t-if="record.email.raw_value">
                                    <strong>Email:</strong>
                                    <field name="email"/>
                                </div>
                                <div t-if="record.phone.raw_value">
                                    <strong>Phone:</strong>
                                    <field name="phone"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List View -->
    <record id="view_student_tree" model="ir.ui.view">
        <field name="name">student.list</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="course"/>
                <field name="year"/>
                <field name="class_name"/>
                <field name="email"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.form</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                        <field name="name"/>
                        <field name="student_id"/>
                        <field name="date_of_birth"/>
                        <field name="age" readonly="1"/>
                        <field name="gender"/>
                        <field name="class_name"/>
                        <field name="course"/>
                        <field name="year"/>
                        <field name="skills"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="active"/>
                    </group>

                    <footer>
                        <button string="Save" class="btn-primary" special="save"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_student_search" model="ir.ui.view">
        <field name="name">student.search</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_id"/>
                <field name="class_name"/>
                <field name="course"/>
                <field name="year"/>
            </search>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_student_graph" model="ir.ui.view">
        <field name="name">student.graph</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <graph string="Student Analysis">
                <field name="course" type="row"/>
                <field name="year" type="row"/>
                <field name="class_name" type="row"/>
                <field name="record_count" type="measure" string="Students"/>
            </graph>
        </field>
    </record>

    <record id="view_student_pivot" model="ir.ui.view">
        <field name="name">student.pivot</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <pivot string="Student Analysis">
                <field name="class_name" type="row"/>
                <field name="gender" type="col"/>
                <field name="record_count" type="measure" string="Students"/>
            </pivot>
        </field>
    </record>
</odoo>
